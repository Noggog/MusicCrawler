# Copy to `.env` (next to compose.yaml) and fill in. `.env` is gitignored — never commit secrets.
# Komodo can inject these instead of a file if you prefer.

# Host port the app's HTTP server is published on. Point your reverse proxy at this.
HTTP_PORT=43105

# Public URL your reverse proxy serves this app at (scheme + host, no trailing slash). Drives the
# OIDC redirect and must match the redirect URI registered in Authentik (origin + /signin-oidc).
BFF_PUBLIC_ORIGIN=https://music.example.com

# --- OIDC (Authentik) ---
# Authority is the application's issuer URL (note the trailing slash).
OIDC_AUTHORITY=https://authentik.example.com/application/o/music-crawler/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# --- Plex ---
PLEX_ENDPOINT=http://192.168.1.232:32400
PLEX_TOKEN=
# PLEX_LIBRARY=Music   # optional; defaults to the first artist-type library

# --- Deezer downloads (streamrip) ---
# Host path to the music library Plex scans; downloads land here (bind-mounted to /music).
MUSIC_DOWNLOAD_DIR_HOST=/srv/media/music
# Host path holding streamrip's config (config.toml with your Deezer ARL). Created on first run.
STREAMRIP_CONFIG_HOST=/srv/appdata/musiccrawler/streamrip
# DEEZER_DOWNLOADS_AUTOMATIC=false   # true = background auto-drain; the button works regardless
# DEEZER_QUALITY=2                   # 2 = FLAC, 1 = 320 kbps MP3
# DEEZER_FALLBACK_QUALITY=1
